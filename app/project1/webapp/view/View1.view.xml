<mvc:View
  controllerName="project1.controller.View1"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  >

  <Page title="Books List">
    <content>

      <VBox>
        <Button text="Refresh Data" press="onRefresh" width="150px"/>

        <Table
          id="booksTable"
          items="{/Books}"
          inset="false">

          <columns>
            <Column>
              <Text text="ID"/>
            </Column>
            <Column>
              <Text text="Title"/>
            </Column>
            <Column>
              <Text text="Author"/>
            </Column>
          </columns>

          <items>
            <ColumnListItem>
              <cells>
                <Text text="{ID}"/>
                <Text text="{title}"/>
                <Text text="{author}"/>
              </cells>
            </ColumnListItem>
          </items>

        </Table>
      </VBox>

    </content>
  </Page>

</mvc:View>